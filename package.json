  "dependencies": {
    "crypto-js": "^4.2.0",
    "set-value": "^4.1.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/set-value": "^4.0.3",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "description": "Framework-agnostic core runtime for 18ways",
  "packageManager": "bun@1.3.8"
}
