{
  "name": "@18ways/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    },
    "./common": {
      "types": "./common.ts",
      "import": "./common.ts"
    },
    "./client-accepted-locales": {
      "types": "./client-accepted-locales.ts",
      "import": "./client-accepted-locales.ts"
    },
    "./client-locale-coordination": {
      "types": "./client-locale-coordination.ts",
      "import": "./client-locale-coordination.ts"
    },
    "./crypto": {
      "types": "./crypto.ts",
      "import": "./crypto.ts"
    },
    "./cookie-utils": {
      "types": "./cookie-utils.ts",
      "import": "./cookie-utils.ts"
    },
    "./i18n-shared": {
      "types": "./i18n-shared.ts",
      "import": "./i18n-shared.ts"
    },
    "./locale-drivers": {
      "types": "./locale-drivers.ts",
      "import": "./locale-drivers.ts"
    },
    "./locale-engine": {
      "types": "./locale-engine.ts",
      "import": "./locale-engine.ts"
    },
    "./object-utils": {
      "types": "./object-utils.ts",
      "import": "./object-utils.ts"
    },
    "./path-locale-driver": {
      "types": "./path-locale-driver.ts",
      "import": "./path-locale-driver.ts"
    },
    "./translation-store": {
      "types": "./translation-store.ts",
      "import": "./translation-store.ts"
    },
    "./internal-i18n": {
      "types": "./internal-i18n.ts",
      "import": "./internal-i18n.ts"
    },
    "./engine": {
      "types": "./engine.ts",
      "import": "./engine.ts"
    },
    "./parsers/ways-parser": {
      "types": "./parsers/ways-parser.ts",
      "import": "./parsers/ways-parser.ts"
    },
    "./parsers/intl-runtime": {
      "types": "./parsers/intl-runtime.ts",
      "import": "./parsers/intl-runtime.ts"
    }
  },
  "scripts": {
    "build": "echo '18ways-core build: source-only package'",
    "ts:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "e2e": "bun run e2e/run-core-e2e.ts"
